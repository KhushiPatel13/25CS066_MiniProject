#include <iostream>
#include <map>
#include <ctime>
#include <cstdlib>

using namespace std;

const int OTP_EXPIRY = 30;
const int MAX_LOGIN_ATTEMPTS = 5;
const int LOCK_TIME = 60;

struct User {
    string password;
    int attempts = 0;
    bool locked = false;
    time_t unlockTime = 0;
};

struct OTP {
    string code;
    time_t timeGenerated;
};

map<string, User> users;
map<string, OTP> sessions;

string generateOTP() {
    return to_string(100000 + rand() % 900000);
}

time_t now() {
    return time(0);
}

bool expired(OTP &o) {
    return (now() - o.timeGenerated) > OTP_EXPIRY;
}

class LoginSystem {
public:
    LoginSystem() {
        users["alice"] = {"pass123"};
        users["bob"] = {"secure!"};
    }

    bool checkPassword(string uname, string pass) {
        if (users.find(uname) == users.end()) {
            cout << "User not found\n";
            return false;
        }

        User &u = users[uname];

        if (u.locked && now() < u.unlockTime) {
            cout << "Account locked\n";
            return false;
        }

        if (pass != u.password) {
            u.attempts++;
            if (u.attempts >= MAX_LOGIN_ATTEMPTS) {
                u.locked = true;
                u.unlockTime = now() + LOCK_TIME;
                cout << "Account locked\n";
            } else {
                cout << "Wrong password\n";
            }
            return false;
        }

        u.attempts = 0;
        return true;
    }

    void sendOTP(string uname) {
        OTP o;
        o.code = generateOTP();
        o.timeGenerated = now();

        sessions[uname] = o;

        cout << "OTP: " << o.code << " (valid 30s)\n";
    }

    bool verifyOTP(string uname, string input) {
        if (sessions.find(uname) == sessions.end()) {
            cout << "No OTP session\n";
            return false;
        }

        OTP &o = sessions[uname];

        // Expired → no second chance
        if (expired(o)) {
            cout << "OTP expired. Login failed\n";
            sessions.erase(uname);
            return false;
        }

        // Only ONE attempt
        if (input != o.code) {
            cout << "Wrong OTP. Login failed\n";
            sessions.erase(uname);
            return false;
        }

        sessions.erase(uname);
        return true;
    }

    void login() {
        string uname, pass, otp;

        cout << "Username: ";
        cin >> uname;
        cout << "Password: ";
        cin >> pass;

        if (!checkPassword(uname, pass)) return;

        sendOTP(uname);

        // ONLY ONE CHANCE
        cout << "Enter OTP: ";
        cin >> otp;

        if (verifyOTP(uname, otp)) {
            cout << "Login successful\n";
        } else {
            cout << "Login failed\n";
        }
    }
};

int main() {
    srand(time(0));
    LoginSystem sys;

    int choice;
    while (true) {
        cout << "\n1. Login\n2. Exit\nChoice: ";
        cin >> choice;

        if (choice == 1) sys.login();
        else break;
    }

    return 0;
}